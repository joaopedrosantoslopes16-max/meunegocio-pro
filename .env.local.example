# Supabase — copie do painel em https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Service Role — NUNCA expor no frontend. Só para routes de API.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Webhook — token secreto para validar webhooks da Kirvano/Kiwify/Hotmart
WEBHOOK_SECRET=seu-token-secreto-aqui

# Checkout — planos mensais
NEXT_PUBLIC_CHECKOUT_URL=https://SEU-LINK-CHECKOUT-ESSENCIAL.com
NEXT_PUBLIC_CHECKOUT_URL_PRO=https://SEU-LINK-CHECKOUT-PRO.com

# Checkout — pacotes extras (one-time)
NEXT_PUBLIC_CHECKOUT_INSTAGRAM_EXTRA=https://SEU-LINK-CHECKOUT-INSTAGRAM-EXTRA.com
NEXT_PUBLIC_CHECKOUT_STORIES=https://SEU-LINK-CHECKOUT-STORIES.com
NEXT_PUBLIC_CHECKOUT_REATIVACAO=https://SEU-LINK-CHECKOUT-REATIVACAO.com

# Suporte — e-mail exibido nas páginas de erro e suporte
NEXT_PUBLIC_SUPPORT_EMAIL=seuemail@gmail.com

# URL base da aplicação (para links do mini site, sem barra no final)
NEXT_PUBLIC_APP_URL=https://meunegocio.pro
